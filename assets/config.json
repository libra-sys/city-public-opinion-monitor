{
  "system": {
    "name": "城市舆情监测分析系统",
    "version": "1.0.0",
    "description": "City Public Opinion Monitoring and Analysis System",
    "author": "AI Agent Skill Team",
    "language": "zh-CN"
  },
  "monitoring": {
    "default_days": 7,
    "max_days": 30,
    "max_records": 5000,
    "update_interval_minutes": 60,
    "data_sources": {
      "news": {
        "enabled": true,
        "priority": 1,
        "label": "新闻媒体",
        "platforms": ["新华网", "人民网", "澎湃新闻", "新京报", "南方都市报", "地方新闻网站"],
        "collection_method": "api"
      },
      "social_media": {
        "enabled": true,
        "priority": 1,
        "label": "社交媒体",
        "platforms": ["微博", "微信", "抖音", "快手", "小红书"],
        "collection_method": "api"
      },
      "forums": {
        "enabled": true,
        "priority": 2,
        "label": "网络论坛",
        "platforms": ["知乎", "百度贴吧", "豆瓣", "地方论坛"],
        "collection_method": "scrape"
      },
      "government": {
        "enabled": true,
        "priority": 2,
        "label": "政府公告",
        "platforms": ["中国政府网", "地方政府网站", "政务微博", "政务微信"],
        "collection_method": "api"
      },
      "video": {
        "enabled": false,
        "priority": 3,
        "label": "视频平台",
        "platforms": ["B站", "西瓜视频"],
        "collection_method": "scrape"
      }
    }
  },
  "sentiment": {
    "method": "dictionary",
    "categories": ["positive", "negative", "neutral", "sensitive"],
    "labels_cn": {
      "positive": "正面",
      "negative": "负面",
      "neutral": "中性",
      "sensitive": "敏感"
    },
    "thresholds": {
      "confidence_min": 0.5,
      "sensitive_trigger": 0.7,
      "review_threshold": 0.65
    },
    "audit": {
      "required": true,
      "trace_original_text": true,
      "store_evidence": true,
      "sample_rate": 0.2
    }
  },
  "risk": {
    "levels": [
      {"level": 1, "name": "极低风险", "score_range": [0, 20], "color": "#52C41A", "response": "常规监测"},
      {"level": 2, "name": "低风险", "score_range": [20, 40], "color": "#73D13D", "response": "关注跟踪"},
      {"level": 3, "name": "中风险", "score_range": [40, 60], "color": "#FAAD14", "response": "分析研判"},
      {"level": 4, "name": "高风险", "score_range": [60, 80], "color": "#FF7A45", "response": "启动预案"},
      {"level": 5, "name": "极高风险", "score_range": [80, 100], "color": "#F5222D", "response": "紧急响应"}
    ],
    "weights": {
      "spread_heat": 0.25,
      "negative_ratio": 0.30,
      "spread_speed": 0.20,
      "opinion_leader": 0.15,
      "cross_platform": 0.10
    },
    "auto_alert": {
      "enabled": true,
      "alert_level": 3,
      "alert_channels": ["email", "sms"],
      "cooldown_minutes": 30
    }
  },
  "keywords": {
    "extraction": {
      "tfidf_top_n": 20,
      "textrank_top_n": 10,
      "min_frequency": 3,
      "min_length": 2
    },
    "clustering": {
      "method": "lda",
      "topic_count": 10,
      "min_docs_per_topic": 5
    }
  },
  "report": {
    "types": ["daily", "weekly", "special", "monthly"],
    "formats": ["json", "markdown", "html"],
    "sections_required": [
      "monitoring_overview",
      "sentiment_analysis",
      "hot_topics",
      "risk_assessment",
      "trend_prediction",
      "recommendations",
      "data_sources"
    ],
    "disclaimer": "本报告由 AI 辅助生成，仅供参考。数据来源为公开网络信息。",
    "watermark": "AI生成 - 仅供参考"
  },
  "compliance": {
    "require_source_citation": true,
    "require_disclaimer": true,
    "require_sentiment_audit_trail": true,
    "require_risk_quantification": true,
    "personal_info_removal": true,
    "data_retention_days": 90
  }
}
